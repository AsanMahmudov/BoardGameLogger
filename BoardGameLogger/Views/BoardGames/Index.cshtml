@model IEnumerable<BoardGameLogger.Web.Models.ViewModels.BoardGameIndexViewModel>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Board Game Library</h1>
    <a asp-action="Create" class="btn btn-primary">Add New Game</a>
</div>

<table class="table table-hover border">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Publisher</th>
            <th>Year</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var game in Model)
        {
            <tr>
                <td>@game.Title</td>
                <td>@game.PublisherName</td>
                <td>@game.YearPublished</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@game.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@game.Id" class="btn btn-sm btn-danger">Delete</a>
                    <a asp-action="Details" asp-route-id="@game.Id" class="btn btn-sm btn-info">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>