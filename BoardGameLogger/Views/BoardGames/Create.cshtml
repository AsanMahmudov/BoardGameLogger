@model BoardGameLogger.Core.ViewModels.BoardGameFormModel

<h1>@(ViewContext.RouteData.Values["action"]?.ToString() == "Edit" ? "Edit Game" : "Add New Game")</h1>
<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="@ViewContext.RouteData.Values["action"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="row mb-3">
                <div class="col">
                    <label asp-for="YearPublished" class="form-label">Year</label>
                    <input asp-for="YearPublished" class="form-control" />
                    <span asp-validation-for="YearPublished" class="text-danger"></span>
                </div>
                <div class="col">
                    <label asp-for="SelectedPublisherId" class="form-label">Publisher</label>
                    <select asp-for="SelectedPublisherId" asp-items="@Model.Publishers" class="form-select">
                        <option value="">-- Select Publisher --</option>
                    </select>
                    <span asp-validation-for="SelectedPublisherId" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col">
                    <label asp-for="MinPlayers" class="form-label"></label>
                    <input asp-for="MinPlayers" class="form-control" />
                    <span asp-validation-for="MinPlayers" class="text-danger"></span>
                </div>
                <div class="col">
                    <label asp-for="MaxPlayers" class="form-label"></label>
                    <input asp-for="MaxPlayers" class="form-control" />
                    <span asp-validation-for="MaxPlayers" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">Save Game</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}