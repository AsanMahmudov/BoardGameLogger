@model BoardGameLogger.Core.ViewModels.BoardGameFormModel

@{
    ViewData["Title"] = "Edit Board Game";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h2 class="mb-0">Edit: @Model.Title</h2>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="YearPublished" class="form-label"></label>
                        <input asp-for="YearPublished" class="form-control" />
                        <span asp-validation-for="YearPublished" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SelectedPublisherId" class="form-label">Publisher</label>
                        <select asp-for="SelectedPublisherId" asp-items="@Model.Publishers" class="form-select">
                            <option value="">-- Change Publisher --</option>
                        </select>
                        <span asp-validation-for="SelectedPublisherId" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="MinPlayers" class="form-label"></label>
                        <input asp-for="MinPlayers" class="form-control" />
                        <span asp-validation-for="MinPlayers" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MaxPlayers" class="form-label"></label>
                        <input asp-for="MaxPlayers" class="form-control" />
                        <span asp-validation-for="MaxPlayers" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}