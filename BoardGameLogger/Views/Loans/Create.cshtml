@model BoardGameLogger.Core.ViewModels.LoanGameFormModel

<div class="container mt-4">
    <h3>Loan out: @Model.BoardGameTitle</h3>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Create" method="post">
                <input type="hidden" asp-for="BoardGameId" />
                <input type="hidden" asp-for="BoardGameTitle" />

                <div class="mb-3">
                    <label asp-for="BorrowerName" class="form-label">Borrower Name</label>
                    <input asp-for="BorrowerName" class="form-control" placeholder="Who is taking it?" />
                    <span asp-validation-for="BorrowerName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LoanDate" class="form-label">Date</label>
                    <input asp-for="LoanDate" class="form-control" type="date" />
                </div>

                <button type="submit" class="btn btn-primary"">
                    Add Loan
                </button>
                <a asp-controller="BoardGames" asp-action="Details" asp-route-id="@Model.BoardGameId" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}