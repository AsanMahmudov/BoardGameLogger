@model IEnumerable<BoardGameLogger.Core.ViewModels.PublisherViewModel>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Publishers</h1>
    <a asp-action="Create" class="btn btn-primary">Add New Publisher</a>
</div>

<table class="table table-hover border">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Country</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Name</td>
                <td>@(p.Country ?? "N/A")</td>
                <td class="text-center">
                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>